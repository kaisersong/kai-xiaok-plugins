{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slide-creator.local/schemas/preset-contract.schema.json",
  "title": "Slide Creator Preset Contract",
  "type": "object",
  "required": [
    "contract_version",
    "preset",
    "support_state",
    "renderer_strategy",
    "renderer_version",
    "source_reference",
    "fonts",
    "tokens",
    "layout_families",
    "required_visible_components",
    "critical_selectors",
    "decorative_selectors",
    "non_critical_selectors",
    "allowed_overlaps",
    "forbidden_substitutions",
    "typography_policy",
    "background_strategy",
    "style_fidelity",
    "export_dom_mapping",
    "browser_qa_policy",
    "demo_parity_minimum_score"
  ],
  "properties": {
    "contract_version": { "type": "integer", "minimum": 1 },
    "preset": { "type": "string", "minLength": 1 },
    "support_state": { "type": "string", "minLength": 1 },
    "renderer_strategy": { "type": "string", "minLength": 1 },
    "renderer_version": { "type": "string", "minLength": 1 },
    "source_reference": { "type": "string", "minLength": 1 },
    "fonts": { "type": "array", "items": { "type": "string" } },
    "tokens": { "type": "object" },
    "layout_families": { "type": "array", "items": { "type": "string" } },
    "required_visible_components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "selectors", "min_count"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "selectors": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "min_count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "critical_selectors": { "type": "array", "items": { "type": "string" } },
    "decorative_selectors": { "type": "array", "items": { "type": "string" } },
    "non_critical_selectors": { "type": "array", "items": { "type": "string" } },
    "allowed_overlaps": { "type": "array", "items": { "type": "string" } },
    "forbidden_substitutions": { "type": "array", "items": { "type": "string" } },
    "typography_policy": { "type": "object" },
    "background_strategy": { "type": "string" },
    "style_fidelity": { "$ref": "#/$defs/styleFidelity" },
    "runtime_fidelity": { "$ref": "#/$defs/runtimeFidelity" },
    "export_dom_mapping": { "type": "object" },
    "browser_qa_policy": { "type": "object" },
    "demo_parity_minimum_score": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "$defs": {
    "selectorGroup": {
      "type": "object",
      "required": ["name", "selectors", "match", "scope", "minimum_group_score", "content_required"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "selectors": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "match": { "enum": ["all", "any"] },
        "scope": { "enum": ["document", "slide"] },
        "page_buckets": { "type": "array", "items": { "enum": ["cover", "content", "closing"] }, "uniqueItems": true },
        "weight": { "type": "number", "exclusiveMinimum": 0 },
        "minimum_group_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_bucket_count": { "type": "integer", "minimum": 1 },
        "content_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "styleFidelity": {
      "type": "object",
      "required": ["minimum_coverage", "minimum_integrity", "required_selector_groups"],
      "properties": {
        "minimum_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "minimum_integrity": { "type": "number", "minimum": 0, "maximum": 1 },
        "required_selector_groups": { "type": "array", "items": { "$ref": "#/$defs/selectorGroup" }, "minItems": 1 },
        "negative_fixtures": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "motionScenario": {
      "type": "object",
      "required": ["name", "trigger", "selectors", "match", "required_page_buckets"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "trigger": { "enum": ["initial-load", "navigate"] },
        "selectors": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "match": { "enum": ["any-visible", "all-visible"] },
        "required_page_buckets": { "type": "array", "items": { "enum": ["cover", "content", "closing"] }, "minItems": 1, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "runtimeFidelity": {
      "type": "object",
      "required": ["runtime_owner", "required_dom", "motion_scenarios", "sample_ms"],
      "properties": {
        "runtime_owner": { "type": "string", "minLength": 1 },
        "required_dom": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "motion_scenarios": { "type": "array", "items": { "$ref": "#/$defs/motionScenario" }, "minItems": 1 },
        "sample_ms": { "type": "integer", "minimum": 1, "maximum": 5000 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
