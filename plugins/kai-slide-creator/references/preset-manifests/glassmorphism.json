{
  "version": 1,
  "preset": "Glassmorphism",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/glassmorphism.md",
  "fonts": [
    "-apple-system",
    "blinkmacsystemfont",
    "noto sans cjk sc",
    "pingfang sc",
    "sans-serif",
    "segoe ui",
    "sf pro display",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--bg-gradient-1": "#000",
      "--bg-gradient-2": "#1a1a2e",
      "--bg-gradient-3": "#1d6fa4",
      "--body-size": "#667eea",
      "--content-gap": "#764ba2",
      "--duration-normal": "#999",
      "--ease-out-expo": "#a6c1ee",
      "--glass-bg": "#a8edea",
      "--glass-border": "#f093fb",
      "--glass-text-dark": "#f8cdda",
      "--glass-text-light": "#fed6e3",
      "--h2-size": "#fff",
      "--orb-mint": "rgba(0,0,0,0.08)",
      "--orb-pink": "rgba(0,0,0,0.10)",
      "--orb-purple": "rgba(0,0,0,0.15)",
      "--slide-padding": "rgba(0,0,0,0.5)",
      "--small-size": "rgba(102,126,234,0.15)",
      "--title-size": "rgba(102,126,234,0.3)"
    },
    "colors": [
      "#000",
      "#1a1a2e",
      "#1d6fa4",
      "#667eea",
      "#764ba2",
      "#999",
      "#a6c1ee",
      "#a8edea",
      "#f093fb",
      "#f8cdda",
      "#fed6e3",
      "#fff",
      "rgba(0,0,0,0.08)",
      "rgba(0,0,0,0.10)",
      "rgba(0,0,0,0.15)",
      "rgba(0,0,0,0.5)",
      "rgba(102,126,234,0.15)",
      "rgba(102,126,234,0.3)",
      "rgba(102,126,234,0.5)",
      "rgba(168,237,234,0.4)"
    ]
  },
  "layout_families": [
    "glass_hero",
    "glass_card",
    "glass_split",
    "glass_trio",
    "glass_stat"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-glassmorphism-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".glass-title",
          ".glass-card",
          ".glass-item",
          ".glass-body",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-glassmorphism-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
