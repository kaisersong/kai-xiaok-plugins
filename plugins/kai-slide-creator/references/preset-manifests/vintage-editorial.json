{
  "version": 1,
  "preset": "Vintage Editorial",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/vintage-editorial.md",
  "fonts": [
    "courier new",
    "fraunces",
    "monospace",
    "noto sans sc",
    "sans-serif",
    "serif",
    "system-ui",
    "work sans"
  ],
  "tokens": {
    "css_vars": {
      "--accent-burgundy": "#000",
      "--accent-warm": "#1a1a1a",
      "--bg-cream": "#555",
      "--pdh": "#555555",
      "--pdw": "#5a2a1a",
      "--pox": "#666",
      "--poy": "#6a1c28",
      "--ps": "#888",
      "--text-primary": "#8b2635",
      "--text-secondary": "#aaa"
    },
    "colors": [
      "#000",
      "#1a1a1a",
      "#555",
      "#555555",
      "#5a2a1a",
      "#666",
      "#6a1c28",
      "#888",
      "#8b2635",
      "#aaa",
      "#e8d4c0",
      "#f5f3ee",
      "#fff"
    ]
  },
  "layout_families": [
    "vintage_masthead",
    "vintage_columns",
    "vintage_pullquote",
    "vintage_index",
    "vintage_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-vintage-editorial-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [
    ".editorial-rule",
    ".rule",
    ".rule-thick"
  ],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".display-title",
          ".headline",
          ".pullquote",
          ".step-editorial",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-vintage-editorial-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
