{
  "version": 1,
  "preset": "Electric Studio",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/electric-studio.md",
  "fonts": [
    "manrope",
    "monospace",
    "noto sans sc",
    "sans-serif",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--accent": "#000",
      "--accent-blue": "#0a0a0a",
      "--bg-dark": "#4361ee",
      "--bg-light": "#999",
      "--bg-white": "#f4f5f9",
      "--body-size": "#f8f9ff",
      "--content-gap": "#fff",
      "--duration-normal": "#ffffff",
      "--ease-out-expo": "rgba(0,0,0,0.18)",
      "--font-body": "rgba(0,0,0,0.5)",
      "--font-display": "rgba(0,0,0,0.6)",
      "--h2-size": "rgba(0,0,0,0.78)",
      "--slide-padding": "rgba(10,10,10,0.06)",
      "--small-size": "rgba(10,10,10,0.4)",
      "--subtitle-size": "#000",
      "--text-dark": "#0a0a0a",
      "--text-light": "#4361ee",
      "--text-secondary": "#999",
      "--title-size": "#f4f5f9"
    },
    "colors": [
      "#000",
      "#0a0a0a",
      "#4361ee",
      "#999",
      "#f4f5f9",
      "#f8f9ff",
      "#fff",
      "#ffffff",
      "rgba(0,0,0,0.18)",
      "rgba(0,0,0,0.5)",
      "rgba(0,0,0,0.6)",
      "rgba(0,0,0,0.78)",
      "rgba(10,10,10,0.06)",
      "rgba(10,10,10,0.4)"
    ]
  },
  "layout_families": [
    "electric_cover",
    "electric_panels",
    "electric_quote",
    "electric_grid",
    "electric_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-electric-studio-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".elec-title",
          ".elec-body",
          ".badge-pill",
          ".feat-name",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-electric-studio-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
