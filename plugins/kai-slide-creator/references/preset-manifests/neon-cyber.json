{
  "version": 1,
  "preset": "Neon Cyber",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/neon-cyber.md",
  "fonts": [
    "-apple-system",
    "clash display",
    "jetbrains mono",
    "monospace",
    "sans-serif",
    "satoshi"
  ],
  "tokens": {
    "css_vars": {
      "--bg": "#000",
      "--bg-panel": "#00ffcc",
      "--body-size": "#0a0f1c",
      "--border-glow": "#0e1525",
      "--content-gap": "#e0f0ff",
      "--cyan": "#ff00aa",
      "--duration-normal": "rgba(0,0,0,0.5)",
      "--ease-out-expo": "rgba(0,255,204,0.01)",
      "--grid": "rgba(0,255,204,0.03)",
      "--h2-size": "rgba(0,255,204,0.04)",
      "--magenta": "rgba(0,255,204,0.06)",
      "--slide-padding": "rgba(0,255,204,0.1)",
      "--small-size": "rgba(0,255,204,0.15)",
      "--text": "#000",
      "--text-muted": "#00ffcc",
      "--title-size": "#0a0f1c"
    },
    "colors": [
      "#000",
      "#00ffcc",
      "#0a0f1c",
      "#0e1525",
      "#e0f0ff",
      "#ff00aa",
      "rgba(0,0,0,0.5)",
      "rgba(0,255,204,0.01)",
      "rgba(0,255,204,0.03)",
      "rgba(0,255,204,0.04)",
      "rgba(0,255,204,0.06)",
      "rgba(0,255,204,0.1)",
      "rgba(0,255,204,0.15)"
    ]
  },
  "layout_families": [
    "cyber_cover",
    "cyber_grid",
    "cyber_terminal",
    "cyber_split",
    "cyber_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-neon-cyber-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".cyber-title",
          ".cyber-card",
          ".cyber-heading",
          ".neon-body",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-neon-cyber-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
