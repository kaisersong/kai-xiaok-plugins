{
  "version": 1,
  "preset": "Aurora Mesh",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/aurora-mesh.md",
  "fonts": [
    "dm sans",
    "monospace",
    "noto sans sc",
    "sans-serif",
    "space grotesk",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--accent": "#000",
      "--bg-primary": "#00b4ff",
      "--body-size": "#00f5c4",
      "--card-bg": "#0a0a1a",
      "--card-border": "#999",
      "--content-gap": "#fff",
      "--divider": "#ffffff",
      "--font-body": "rgba(0,0,0,0.5)",
      "--font-display": "rgba(0,0,0,0.6)",
      "--h2-size": "rgba(0,0,0,0.78)",
      "--slide-padding": "rgba(0,180,255,0.30)",
      "--subtitle-size": "rgba(0,245,196,0.12)",
      "--text-body": "rgba(0,245,196,0.3)",
      "--text-muted": "rgba(0,245,196,0.30)",
      "--text-primary": "rgba(0,245,196,0.40)",
      "--title-size": "rgba(0,255,180,0.20)"
    },
    "colors": [
      "#000",
      "#00b4ff",
      "#00f5c4",
      "#0a0a1a",
      "#999",
      "#fff",
      "#ffffff",
      "rgba(0,0,0,0.5)",
      "rgba(0,0,0,0.6)",
      "rgba(0,0,0,0.78)",
      "rgba(0,180,255,0.30)",
      "rgba(0,245,196,0.12)",
      "rgba(0,245,196,0.3)",
      "rgba(0,245,196,0.30)",
      "rgba(0,245,196,0.40)",
      "rgba(0,255,180,0.20)"
    ]
  },
  "layout_families": [
    "aurora_hero",
    "aurora_card",
    "aurora_stat",
    "aurora_split",
    "aurora_trio",
    "aurora_timeline"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-aurora-mesh-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [
    ".aurora-divider"
  ],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".aurora-card",
          ".aurora-title",
          ".aurora-subtitle",
          ".aurora-stat",
          ".a-title",
          ".a-h2",
          ".a-body"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-aurora-mesh-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
