{
  "version": 1,
  "preset": "Chinese Chan",
  "support_state": "native_deterministic_core",
  "renderer_strategy": "native",
  "source_reference": "references/chinese-chan.md",
  "fonts": [
    "system-ui",
    "sans-serif"
  ],
  "tokens": {
    "css_vars": {},
    "colors": []
  },
  "layout_families": [
    "native"
  ],
  "signature_components": [
    "slide",
    "title",
    "content",
    "export-role"
  ],
  "required_visible_components": [
    {
      "name": "slide",
      "selectors": [
        "section.slide"
      ],
      "min_count": 1
    },
    {
      "name": "title",
      "selectors": [
        "h1, h2"
      ],
      "min_count": 1
    },
    {
      "name": "content",
      "selectors": [
        ".slide-content, .content, section.slide"
      ],
      "min_count": 1
    },
    {
      "name": "export-role",
      "selectors": [
        "section.slide[data-export-role]"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-content-present",
        "selectors": [
          ".preset-chinese-chan-content",
          ".zen-content",
          ".zen-title",
          ".zen-h2",
          ".zen-body",
          ".zen-stat",
          ".zen-vertical-title"
        ],
        "match": "any",
        "scope": "document",
        "weight": 3.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-chinese-chan-content",
          ".zen-content",
          ".zen-title",
          ".zen-h2",
          ".zen-body",
          ".zen-stat",
          ".zen-vertical-title"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.5,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump"
    ]
  }
}
