{
  "version": 1,
  "preset": "Split Pastel",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/split-pastel.md",
  "fonts": [
    "fira code",
    "monospace",
    "noto sans sc",
    "outfit",
    "sans-serif",
    "sf mono",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--accent": "#000",
      "--badge-lavender": "#1a1a1a",
      "--badge-mint": "#666666",
      "--badge-peach": "#b0e0c0",
      "--badge-pink": "#b8a08a",
      "--badge-yellow": "#c8f0d8",
      "--bg-lavender": "#d4cef5",
      "--bg-peach": "#e4dff0",
      "--body-size": "#f0d4c0",
      "--content-gap": "#f0d4e0",
      "--font-body": "#f0f0c8",
      "--font-display": "#f5d4c4",
      "--h2-size": "#f5e6dc",
      "--slide-padding": "#fff",
      "--small-size": "#000",
      "--text-dark": "#1a1a1a",
      "--text-secondary": "#666666",
      "--title-size": "#b0e0c0"
    },
    "colors": [
      "#000",
      "#1a1a1a",
      "#666666",
      "#b0e0c0",
      "#b8a08a",
      "#c8f0d8",
      "#d4cef5",
      "#e4dff0",
      "#f0d4c0",
      "#f0d4e0",
      "#f0f0c8",
      "#f5d4c4",
      "#f5e6dc",
      "#fff"
    ]
  },
  "layout_families": [
    "split_cover",
    "split_statement",
    "split_cards",
    "split_timeline",
    "split_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-split-pastel-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".hero-title-main",
          ".preview-card",
          ".steps-container",
          ".pain-text",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-split-pastel-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
