{
  "version": 1,
  "preset": "Pastel Geometry",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/pastel-geometry.md",
  "fonts": [
    "monospace",
    "noto sans sc",
    "plus jakarta sans",
    "sans-serif",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--accent": "#000",
      "--bg-primary": "#1a1a1a",
      "--body-size": "#1a2530",
      "--card-bg": "#666666",
      "--content-gap": "#7bb8d4",
      "--font-body": "#8fad9a",
      "--font-display": "#9b8dc4",
      "--h2-size": "#a8d4c4",
      "--pill-lavender": "#c8d9e6",
      "--pill-mint": "#f0b4d4",
      "--pill-peach": "#f0c4a0",
      "--pill-pink": "#faf9f7",
      "--pill-sage": "#fff",
      "--pill-sky": "#000",
      "--slide-padding": "#1a1a1a",
      "--small-size": "#1a2530",
      "--text-primary": "#666666",
      "--text-secondary": "#7bb8d4",
      "--title-size": "#8fad9a"
    },
    "colors": [
      "#000",
      "#1a1a1a",
      "#1a2530",
      "#666666",
      "#7bb8d4",
      "#8fad9a",
      "#9b8dc4",
      "#a8d4c4",
      "#c8d9e6",
      "#f0b4d4",
      "#f0c4a0",
      "#faf9f7",
      "#fff"
    ]
  },
  "layout_families": [
    "geo_cover",
    "geo_grid",
    "geo_split",
    "geo_steps",
    "geo_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-pastel-geometry-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".card-content",
          ".flow-card",
          ".cmd-block",
          ".hero-inner",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-pastel-geometry-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
