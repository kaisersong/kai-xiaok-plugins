{
  "version": 1,
  "preset": "Terminal Green",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/terminal-green.md",
  "fonts": [
    "jetbrains mono",
    "sans-serif",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--bg": "#000",
      "--bg-panel": "#0d1117",
      "--blue": "#111",
      "--body-size": "#161b22",
      "--border": "#30363d",
      "--comment": "#39d353",
      "--content-gap": "#484f58",
      "--duration-normal": "#58a6ff",
      "--ease-out-expo": "#8b949e",
      "--font-mono": "#c9d1d9",
      "--green": "#e3b341",
      "--green-muted": "#f85149",
      "--h2-size": "rgba(0,0,0,0.5)",
      "--red": "#000",
      "--slide-padding": "#0d1117",
      "--small-size": "#111",
      "--text": "#161b22",
      "--text-muted": "#30363d",
      "--title-size": "#39d353",
      "--yellow": "#484f58"
    },
    "colors": [
      "#000",
      "#0d1117",
      "#111",
      "#161b22",
      "#30363d",
      "#39d353",
      "#484f58",
      "#58a6ff",
      "#8b949e",
      "#c9d1d9",
      "#e3b341",
      "#f85149",
      "rgba(0,0,0,0.5)"
    ]
  },
  "layout_families": [
    "terminal_boot",
    "terminal_code",
    "terminal_grid",
    "terminal_timeline",
    "terminal_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-terminal-green-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [
    ".preset-grid",
    ".rule"
  ],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".t-title",
          ".t-h2",
          ".t-body",
          ".t-prompt",
          ".terminal-block",
          ".feature-card",
          ".pain-list",
          ".steps"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-terminal-green-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
