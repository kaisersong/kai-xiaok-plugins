{
  "version": 1,
  "preset": "Modern Newspaper",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/modern-newspaper.md",
  "fonts": [
    "playfair display",
    "sans-serif",
    "source sans 3",
    "source sans pro",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--accent": "#000",
      "--bg": "#111",
      "--card-bg": "#1c1917",
      "--card-border": "#44403c",
      "--divider": "#999",
      "--duration-normal": "#fafaf9",
      "--ease-out-expo": "#fff",
      "--slide-padding": "rgba(0,0,0,0.50)",
      "--text-body": "rgba(0,0,0,0.78)",
      "--text-muted": "rgba(0,0,0,0.85)",
      "--text-primary": "rgba(16,185,129,0.80)",
      "--text-secondary": "#000"
    },
    "colors": [
      "#000",
      "#111",
      "#1c1917",
      "#44403c",
      "#999",
      "#fafaf9",
      "#fff",
      "rgba(0,0,0,0.50)",
      "rgba(0,0,0,0.78)",
      "rgba(0,0,0,0.85)",
      "rgba(16,185,129,0.80)"
    ]
  },
  "layout_families": [
    "newspaper_cover",
    "newspaper_columns",
    "newspaper_stats",
    "newspaper_index",
    "newspaper_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-modern-newspaper-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".np-headline",
          ".np-body",
          ".np-cmd",
          ".np-stamp",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-modern-newspaper-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
