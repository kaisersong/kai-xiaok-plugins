{
  "version": 1,
  "preset": "Neo-Retro Dev Deck",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/neo-retro-dev.md",
  "fonts": [
    "-apple-system",
    "barlow condensed",
    "ibm plex mono",
    "ibm plex sans",
    "monospace",
    "noto sans sc",
    "sans-serif"
  ],
  "tokens": {
    "css_vars": {
      "--accent": "#000",
      "--bg": "#00c8ff",
      "--block-bg": "#111111",
      "--block-dark": "#1a1a1a",
      "--body-size": "#22c55e",
      "--border": "#444",
      "--content-gap": "#666",
      "--cyan": "#888",
      "--green": "#999",
      "--grid": "#f5f2e8",
      "--h2-size": "#f7f5f0",
      "--pink": "#ff3c7e",
      "--slide-padding": "#ffe14d",
      "--small-size": "#fff",
      "--text": "#ffffff",
      "--title-size": "#000",
      "--yellow": "#00c8ff"
    },
    "colors": [
      "#000",
      "#00c8ff",
      "#111111",
      "#1a1a1a",
      "#22c55e",
      "#444",
      "#666",
      "#888",
      "#999",
      "#f5f2e8",
      "#f7f5f0",
      "#ff3c7e",
      "#ffe14d",
      "#fff",
      "#ffffff"
    ]
  },
  "layout_families": [
    "retro_cover",
    "retro_cmd",
    "retro_cards",
    "retro_metrics",
    "retro_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-neo-retro-dev-deck-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".arch-title",
          ".cards-grid",
          ".badge-cyan",
          ".badge-pink",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-neo-retro-dev-deck-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
