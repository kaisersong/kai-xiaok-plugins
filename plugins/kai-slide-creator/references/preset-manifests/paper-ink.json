{
  "version": 1,
  "preset": "Paper & Ink",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "source_reference": "references/paper-ink.md",
  "fonts": [
    "crimson pro",
    "georgia",
    "sans-serif",
    "serif",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--accent": "#000",
      "--bg": "#111",
      "--card-bg": "#1c1917",
      "--card-border": "#999",
      "--divider": "#fefdf8",
      "--duration-normal": "#fff",
      "--ease-out-expo": "rgba(0,0,0,0.50)",
      "--slide-padding": "rgba(0,0,0,0.78)",
      "--text-body": "rgba(0,0,0,0.85)",
      "--text-muted": "rgba(16,185,129,0.80)",
      "--text-primary": "rgba(255,255,255,0.10)",
      "--text-secondary": "#000"
    },
    "colors": [
      "#000",
      "#111",
      "#1c1917",
      "#999",
      "#fefdf8",
      "#fff",
      "rgba(0,0,0,0.50)",
      "rgba(0,0,0,0.78)",
      "rgba(0,0,0,0.85)",
      "rgba(16,185,129,0.80)",
      "rgba(255,255,255,0.10)"
    ]
  },
  "layout_families": [
    "paper_hero",
    "paper_columns",
    "paper_pullquote",
    "paper_index",
    "paper_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-paper-ink-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "decorative_selectors": [
    ".cta-layout",
    ".editing-layout",
    ".hero-layout",
    ".install-layout",
    ".present-mode-layout",
    ".preset-gallery-layout",
    ".problem-layout",
    ".workflow-layout"
  ],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".hero-body",
          ".manifesto-inner",
          ".steps",
          ".pain-list",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-paper-ink-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
