{
  "contract_version": 1,
  "preset": "Electric Studio",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "renderer_version": "2026-06-29.contract-aware-v1",
  "source_reference": "references/electric-studio.md",
  "fonts": [
    "manrope",
    "monospace",
    "noto sans sc",
    "sans-serif",
    "system-ui"
  ],
  "tokens": {
    "css_vars": {
      "--accent": "#000",
      "--accent-blue": "#0a0a0a",
      "--bg-dark": "#4361ee",
      "--bg-light": "#999",
      "--bg-white": "#f4f5f9",
      "--body-size": "#f8f9ff",
      "--content-gap": "#fff",
      "--duration-normal": "#ffffff",
      "--ease-out-expo": "rgba(0,0,0,0.18)",
      "--font-body": "rgba(0,0,0,0.5)",
      "--font-display": "rgba(0,0,0,0.6)",
      "--h2-size": "rgba(0,0,0,0.78)",
      "--slide-padding": "rgba(10,10,10,0.06)",
      "--small-size": "rgba(10,10,10,0.4)",
      "--subtitle-size": "#000",
      "--text-dark": "#0a0a0a",
      "--text-light": "#4361ee",
      "--text-secondary": "#999",
      "--title-size": "#f4f5f9"
    },
    "colors": [
      "#000",
      "#0a0a0a",
      "#4361ee",
      "#999",
      "#f4f5f9",
      "#f8f9ff",
      "#fff",
      "#ffffff",
      "rgba(0,0,0,0.18)",
      "rgba(0,0,0,0.5)",
      "rgba(0,0,0,0.6)",
      "rgba(0,0,0,0.78)",
      "rgba(10,10,10,0.06)",
      "rgba(10,10,10,0.4)"
    ]
  },
  "layout_families": [
    "electric_cover",
    "electric_panels",
    "electric_quote",
    "electric_grid",
    "electric_close"
  ],
  "signature_components": [
    "profile-slide",
    "profile-content",
    "preset-content",
    "profile-title"
  ],
  "required_visible_components": [
    {
      "name": "profile-slide",
      "selectors": [
        "section.profile-slide"
      ],
      "min_count": 1
    },
    {
      "name": "profile-content",
      "selectors": [
        ".profile-content"
      ],
      "min_count": 1
    },
    {
      "name": "preset-content",
      "selectors": [
        ".preset-electric-studio-content"
      ],
      "min_count": 1
    },
    {
      "name": "profile-title",
      "selectors": [
        ".profile-fit-title"
      ],
      "min_count": 1
    }
  ],
  "critical_selectors": [
    "section.slide",
    "h1, h2",
    "[data-export-role]"
  ],
  "decorative_selectors": [],
  "non_critical_selectors": [
    ".slide-num-label",
    ".progress-bar",
    "#presenter-view"
  ],
  "allowed_overlaps": [
    "decorative-background",
    "slide-number-safe-area"
  ],
  "forbidden_substitutions": [
    "generic-theme-shell",
    "marker-only-style-signature",
    "empty-component-shell"
  ],
  "typography_policy": {
    "min_body_contrast": 4.5,
    "max_negative_letter_spacing_px": -1.0,
    "forbid_single_letter_word_break": true,
    "require_title_not_clipped": true
  },
  "background_strategy": "electric_studio",
  "export_dom_mapping": {
    "slide": "section.slide",
    "title": "section.slide h1, section.slide h2, .title-balance",
    "subtitle": "section.slide p, .subtitle, .hero-sub",
    "body": "section.slide p, section.slide li, section.slide .content, section.slide .slide-content",
    "list_items": "section.slide li",
    "code": "section.slide code, section.slide pre, section.slide .code-block, section.slide .cmd-table",
    "quote": "section.slide blockquote, section.slide .pullquote, section.slide .quote, section.slide .sc-quote-block",
    "stat": "section.slide .stat, section.slide .stats, section.slide [class*=stat], section.slide .metric",
    "image": "section.slide img, section.slide picture, section.slide svg",
    "speaker_notes": "section.slide[data-notes]"
  },
  "browser_qa_policy": {
    "desktop_viewports": [
      {
        "width": 1600,
        "height": 900
      },
      {
        "width": 1280,
        "height": 720
      }
    ],
    "mobile_viewports": [
      {
        "width": 390,
        "height": 844
      }
    ],
    "hard_failures": [
      "browser-geometry-title-clipped",
      "browser-geometry-text-overflow",
      "browser-geometry-empty-component",
      "browser-geometry-character-overlap",
      "browser-geometry-low-contrast",
      "browser-geometry-invisible-target"
    ]
  },
  "demo_parity_minimum_score": 0.85,
  "style_fidelity": {
    "minimum_coverage": 0.85,
    "minimum_integrity": 1.0,
    "required_selector_groups": [
      {
        "name": "preset-visual-component",
        "selectors": [
          ".elec-title",
          ".elec-body",
          ".badge-pill",
          ".feat-name",
          ".pill",
          ".stats"
        ],
        "match": "any",
        "scope": "document",
        "weight": 1.0,
        "minimum_group_score": 1.0,
        "content_required": true
      },
      {
        "name": "preset-content-spread",
        "selectors": [
          ".preset-electric-studio-content"
        ],
        "match": "any",
        "scope": "slide",
        "page_buckets": [
          "content"
        ],
        "weight": 1.0,
        "minimum_group_score": 0.7,
        "minimum_bucket_count": 1,
        "content_required": true
      }
    ],
    "negative_fixtures": [
      "generic-shell",
      "marker-only",
      "single-slide-signature-dump",
      "full-slide-image"
    ]
  }
}
