{
  "contract_version": 1,
  "preset": "Glassmorphism",
  "support_state": "unified_profile_renderer",
  "renderer_strategy": "unified_profile",
  "renderer_version": "2026-06-29.contract-aware-v1",
  "source_reference": "references/glassmorphism.md",
  "fonts": [
    "-apple-system",
    "blinkmacsystemfont",
    "noto sans cjk sc",
    "pingfang sc",
    "sans-serif",
