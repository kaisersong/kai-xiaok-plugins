      "--ease-out-expo": "rgba(0,0,0,0.5)",
      "--font-body": "rgba(0,0,0,0.78)",
      "--font-display": "rgba(0,102,255,0.08)",
      "--font-mono": "rgba(0,102,255,0.15)",
