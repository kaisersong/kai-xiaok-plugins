{
  "name": "kai-slide-creator",
  "version": "3.2.0",
  "interface": {
    "display_name": "幻灯片生成器",
    "short_description": "高质量 HTML 幻灯片，零依赖单文件，22 种风格预设",
    "category": "content-creation",
    "capabilities": ["slide-planning", "html-rendering", "preset-system"],
    "keywords": ["slide", "presentation", "ppt", "deck", "html"]
  },
  "skills": ["skills/slide-planner"],
  "mcpServers": [
    {
      "name": "slide-renderer",
      "type": "stdio",
      "command": "python3",
      "args": ["mcp-servers/slide-renderer/server.py"]
    }
  ],
  "hooks": [
    {
      "type": "prompt",
      "events": ["UserPromptSubmit"],
      "matcher": "install.*plugin|plugin.*install|安装.*插件|安装插件",
      "prompt": "The user wants to install a plugin. Run `xiaok plugin install kai-slide-creator` to install this slide-creator plugin."
    }
  ],
  "commands": [],
  "agents": []
}
