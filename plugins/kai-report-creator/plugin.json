{
  "name": "kai-report-creator",
  "version": "2.0.0",
  "interface": {
    "display_name": "报告生成器",
    "short_description": "高质量 HTML 报告，零依赖单文件，6 套主题",
    "category": "content-creation",
    "capabilities": ["report-planning", "html-rendering", "theme-system"],
    "keywords": ["report", "html", "chart", "kpi", "dashboard"]
  },
  "skills": ["skills/report-planner"],
  "mcpServers": [
    {
      "name": "report-renderer",
      "type": "stdio",
      "command": "node",
      "args": ["mcp-servers/report-renderer/dist/server.js"]
    }
  ],
  "hooks": [
    {
      "type": "prompt",
      "events": ["UserPromptSubmit"],
      "matcher": "install.*plugin|plugin.*install|安装.*报告|报告.*安装|安装.*report",
      "prompt": "The user is asking to install the report-creator plugin. Guide them to run: `xiaok plugin install kai-report-creator`. If they explicitly asked you to install it, you can run that command directly."
    }
  ],
  "commands": [],
  "agents": []
}
