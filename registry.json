{
  "version": 1,
  "repo": "kaisersong/kai-xiaok-plugins",
  "plugins": [
    {
      "name": "kai-slide-creator",
      "display_name": "幻灯片生成器",
      "description": "高质量 HTML 幻灯片，22 种风格预设，零依赖单文件",
      "category": "content-creation",
      "keywords": [
        "slide",
        "presentation",
        "ppt",
        "deck",
        "html",
        "幻灯片",
        "演示"
      ],
      "repo": "kaisersong/kai-xiaok-plugins",
      "path": "plugins/kai-slide-creator",
      "version": "3.2.0",
      "dependencies": {
        "runtime": "python3",
        "install": "pip3 install -r mcp-servers/slide-renderer/requirements.txt",
        "test": "cd mcp-servers/slide-renderer && python3 -m pytest tests/ -q"
      }
    },
    {
      "name": "kai-report-creator",
      "display_name": "报告生成器",
      "description": "高质量 HTML 报告，8 套主题，零依赖单文件",
      "category": "content-creation",
      "keywords": [
        "report",
        "html",
        "chart",
        "kpi",
        "dashboard",
        "报告",
        "看板"
      ],
      "repo": "kaisersong/kai-xiaok-plugins",
      "path": "plugins/kai-report-creator",
      "version": "2.1.0",
      "dependencies": {
        "runtime": "node",
        "install": "cd mcp-servers/report-renderer && npm install && npm run build",
        "test": "cd mcp-servers/report-renderer && npx vitest run"
      }
    },
    {
      "name": "kai-meeting-assistant",
      "display_name": "会议助手",
      "description": "Xiaok Desktop AI 录音的本地 Whisper 转写回退与会议纪要总结能力",
      "category": "productivity",
      "keywords": [
        "meeting",
        "recording",
        "transcription",
        "whisper",
        "minutes",
        "会议",
        "录音",
        "转写",
        "纪要"
      ],
      "repo": "kaisersong/kai-xiaok-plugins",
      "path": "plugins/kai-meeting-assistant",
      "version": "0.1.0",
      "platforms": ["darwin", "linux", "win32"],
      "dependencies": {
        "runtime": "python3",
        "install": "pip3 install -r mcp-servers/meeting-transcriber/requirements.txt",
        "test": "python3 -m pytest tests/test_meeting_transcriber.py -q"
      }
    },
    {
      "name": "cua-computer-use",
      "display_name": "Computer Use for Mac",
      "description": "通过 CUA Driver 在 macOS 上观察和操作本机应用",
      "category": "local-automation",
      "keywords": [
        "computer-use",
        "cua",
        "macos",
        "automation",
        "mcp",
        "本机自动化",
        "电脑操作"
      ],
      "repo": "kaisersong/kai-xiaok-plugins",
      "path": "plugins/cua-computer-use",
      "version": "0.2.0",
      "platforms": ["darwin"],
      "dependencies": {
        "runtime": "cua-driver",
        "install": "Use Xiaok Settings to install the official CUA Driver dependency",
        "test": "cua-driver --version && cua-driver check_permissions"
      },
      "externalDependencies": [
        {
          "id": "cua-driver",
          "kind": "macos_app_cli",
          "displayName": "CUA Driver",
          "envOverride": "XIAOK_CUA_DRIVER_CMD",
          "binaryCandidates": [
            "~/.local/bin/cua-driver",
            "/usr/local/bin/cua-driver",
            "/opt/homebrew/bin/cua-driver",
            "cua-driver"
          ],
          "minVersion": "0.1.0",
          "install": {
            "kind": "official_installer",
            "sourceUrl": "https://raw.githubusercontent.com/trycua/cua/main/libs/cua-driver/scripts/install.sh",
            "sourceAllowlist": [
              "https://raw.githubusercontent.com/trycua/cua/main/libs/cua-driver/scripts/install.sh"
            ],
            "requiresUserConfirmation": true
          },
          "update": {
            "kind": "command",
            "command": "~/.local/bin/cua-driver",
            "args": ["update"],
            "requiresUserConfirmation": true
          },
          "health": {
            "version": ["~/.local/bin/cua-driver", "--version"],
            "status": ["~/.local/bin/cua-driver", "status"],
            "permissions": ["~/.local/bin/cua-driver", "check_permissions"],
            "doctor": ["~/.local/bin/cua-driver", "doctor"]
          },
          "mcp": {
            "serverName": "cua-driver",
            "command": "~/.local/bin/cua-driver",
            "args": ["mcp"],
            "requiresUserActivation": true
          },
          "toolPolicy": {
            "defaultPermission": "write",
            "safeTools": ["list_apps", "list_windows", "get_window_state", "screenshot"],
            "hiddenRawToolsInProduct": true,
            "productWrapper": "xiaok_computer_use"
          }
        }
      ],
      "toolPermissions": {
        "defaultMcpToolPermission": "write",
        "tools": {
          "xiaok_computer_use": "write",
          "mcp__cua-driver__get_app_state": "safe",
          "mcp__cua-driver__list_apps": "safe"
        }
      }
    },
    {
      "name": "kai-infinity-canvas",
      "display_name": "无限画布",
      "description": "tldraw 驱动的本地无限画布，支持手绘、标注、图片插入",
      "category": "visual-collaboration",
      "keywords": [
        "canvas",
        "tldraw",
        "whiteboard",
        "画布",
        "白板",
        "手绘"
      ],
      "repo": "kaisersong/kai-xiaok-plugins",
      "path": "plugins/kai-infinity-canvas",
      "version": "0.1.0",
      "platforms": ["darwin", "linux", "win32"],
      "dependencies": {
        "runtime": "node",
        "install": "npm install && npm run build",
        "test": "node tests/mcp.test.mjs"
      }
    }
  ]
}
